{
  "feature": "support",
  "version": "1.0.0",
  "web": {
    "zapBaselineScan": {
      "enabled": true,
      "targetUrl": "${BASE_URL}"
    },
    "tls": {
      "enabled": true,
      "targetUrl": "${API_BASE_URL}"
    }
  },
  "mobile": {
